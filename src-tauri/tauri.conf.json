{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kiro Chat",
  "version": "0.3.0",
  "identifier": "dev.kirochat.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kiro Chat",
        "width": 1000,
        "height": 700,
        "minWidth": 640,
        "minHeight": 480,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Kiro Chat — converse com o Kiro no seu computador",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "PortugueseBR",
          "English"
        ],
        "displayLanguageSelector": false,
        "installerHooks": "installer-hooks.nsh",
        "startMenuFolder": "Kiro Chat"
      }
    }
  }
}
